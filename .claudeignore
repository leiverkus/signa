# .claudeignore
# ----------------------------------------------------------------------
# Prevents Claude Code from loading large binaries, raw data and
# generated outputs into context. Saves tokens, speeds up sessions,
# protects sensitive field data.
#
# Syntax: gitignore-compatible.
# ----------------------------------------------------------------------

# === Raw drone images & field data ===
# Never load into context - 20-60 MB per file, 100s-1000s per site
fieldwork/*/raw/
fieldwork/**/raw/
**/raw/
*.JPG
*.jpg
*.JPEG
*.jpeg
*.DNG
*.dng
*.RAW
*.raw
*.NEF
*.CR2
*.ARW
*.tif
*.TIF
*.tiff
*.TIFF

# === Photogrammetry outputs ===
# Orthomosaics, DEMs, point clouds, mesh - all large and reproducible
*.las
*.laz
*.ply
*.obj
*.fbx
*.3ds
*.glb
*.gltf
*.cog.tif
**/odm_orthophoto/
**/odm_dem/
**/odm_meshing/
**/odm_texturing*/
**/opensfm/
**/odm_filterpoints/
**/odm_georeferencing/
**/cameras.json
**/reconstruction.json

# === WebODM/ODX-ready folder (symlinks are enough, not their contents) ===
fieldwork/*/processed/webodm_ready/images/
**/webodm_ready/images/

# === GIS / geodata formats ===
*.gpkg
*.gpkg-journal
*.gpkg-wal
*.gpkg-shm
*.shp
*.shx
*.dbf
*.prj
*.cpg
*.qix
*.sbn
*.sbx
*.mbtiles
*.pmtiles
*.geotiff
*.aux.xml
*.ovr

# Exception: sample/test geometries are allowed if small
!samples/*.gpkg
!tests/fixtures/*.geojson

# === Logs & reports ===
# Logs are rarely relevant for Claude Code; attach explicitly if needed
*.log
findgcp_*.log
fieldwork/*/processed/*.log
gcp_report.txt

# === Python artifacts ===
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
ENV/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
build/
dist/

# === Node/JS (in case web components are added) ===
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# === IDE & editor ===
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# === Docker / container volumes ===
.docker/
docker-data/
postgres-data/
qgis-server-data/

# === Secrets & credentials ===
# Never load into context - even if accidentally committed
*.env
.env*
!.env.example
*.key
*.pem
*.p12
secrets/
credentials/
*_credentials*
*_token*
.netrc

# === Flutter/Dart build artifacts (if a companion app repo is embedded) ===
**/.dart_tool/
**/.flutter-plugins
**/.flutter-plugins-dependencies
**/build/
**/ios/Pods/
**/android/.gradle/

# === QGIS project files (large, binary-ish) ===
*.qgz
*.qgs~
# Exception: allow lean project definitions
!project.qgs

# === Raw bibliography PDFs ===
# RIS/BibTeX allowed, PDFs not (copyright, size)
literature/**/*.pdf
references/**/*.pdf
zotero_storage/

# === Backups & archives ===
*.zip
*.tar
*.tar.gz
*.tgz
*.bak
*.backup
*.old
*~

# === Temporary files ===
tmp/
temp/
.cache/
*.tmp

# === Always keep in context ===
# (gitignore negations at the end so they take effect)
!CLAUDE.md
!README.md
!*.md
!*.sh
!*.py
!*.toml
!*.yaml
!*.yml
!*.json
!*.txt
!Dockerfile
!docker-compose*.yml
!.gitlab-ci.yml
!.github/
